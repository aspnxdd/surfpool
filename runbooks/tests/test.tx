addon "svm" {
  network_id  = "localnet"
  rpc_api_url = "http://localhost:8899"
}

action "setup_surfnet" "svm::setup_surfnet" {
  set_account {
    public_key = "3BznENHP5KkRikLZqCLGLTaVGcDBsWDTLjSCbHZD2qTA"
    patch_raw = [
      {
        offset = 8
        length = 32
        field_value = "LBUZKhRxPF3XUpBCjp4YzTKgLccjZhTSDM9YuVaPwxo"
        field_type = "pubkey"
      },
      {
        offset = 7960
        length = 32
        field_value = "LBUZKhRxPF3XUpBCjp4YzTKgLccjZhTSDM9YuVaPwxo"
        field_type = "pubkey"
      },
      {
        offset = 7936
        length = 8
        field_value = 5
        field_type = "u64"
      }
    ]

    patch_idl = [
      {
        program_idl = "./idl.json"
        account_name = "PositionV2"
        field_name = "lb_pair"
        field_value = "GdkseahYCNJF5gSpb4Pzsmsj6GQL3Zi8AGTEkniSzGAQ"
      },
      {
        program_idl = "./idl.json"
        account_name = "PositionV2"
        field_name = "lower_bin_id"
        field_value = -3333
      }
    ]
  }
}
