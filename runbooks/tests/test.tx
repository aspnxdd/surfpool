addon "svm" {
  network_id  = "localnet"
  rpc_api_url = "http://localhost:8899"
}

variable "program" {
    description = "The program to to invoke."
    value = svm::get_program_from_anchor_project("lb_clmm")
}

action "setup_surfnet" "svm::setup_surfnet" {
  set_account {
    public_key = "3BznENHP5KkRikLZqCLGLTaVGcDBsWDTLjSCbHZD2qTA"

    patch_raw {
      offset = 8
      length = 32
      value = "LBUZKhRxPF3XUpBCjp4YzTKgLccjZhTSDM9YuVaPwxo"
      type = "pubkey"
    }

    patch_raw { 
      offset = 7960
      length = 32
      value = "LBUZKhRxPF3XUpBCjp4YzTKgLccjZhTSDM9YuVaPwxo"
      type = "pubkey"
    }
    
    patch_raw {  
      offset = 7936
      length = 8
      value = 5
      type = "u64"
    }
    

    patch_idl {
        program_idl = variable.program.idl
        account_name = "PositionV2"
        name = "lb_pair"
        value = "GdkseahYCNJF5gSpb4Pzsmsj6GQL3Zi8AGTEkniSzGAQ"
      }
    patch_idl  {
        program_idl = variable.program.idl
        account_name = "PositionV2"
        name = "lower_bin_id"
        value = -3332
      }
    
  }
}
